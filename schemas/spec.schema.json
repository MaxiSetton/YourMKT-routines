{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Spec de pieza (reel) v2",
  "description": "Contrato que Ideacion (IA) llena y el renderer determinista consume. La escena declara ROL + INTENCION + cadena de FUENTES; el render resuelve contra lo que existe.",
  "type": "object",
  "required": ["id", "arquetipo", "formato", "aspect", "fps", "duracion_seg", "marca", "escenas", "audio", "subtitulos", "copy"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string" },
    "carpeta": { "type": "string", "description": "Subcarpeta de public/ con los assets de ESTA pieza (organizacion por video). Los scripts resuelven recursivamente, asi que es opcional; sirve para saber donde escribir/bajar." },
    "arquetipo": { "type": "string", "enum": ["promo", "tutorial", "antes_despues", "educativo", "detras_escena", "top_n", "testimonio", "novedad"] },
    "formato": { "type": "string", "enum": ["reel", "post", "carrusel"] },
    "aspect": { "type": "string", "enum": ["9:16", "4:5", "1:1", "16:9"] },
    "fps": { "type": "integer", "minimum": 24, "maximum": 60 },
    "duracion_seg": { "type": "number", "minimum": 3, "maximum": 90 },
    "marca": {
      "type": "object",
      "required": ["nombre", "colores", "fuenteTitulo", "fuenteTexto"],
      "properties": {
        "nombre": { "type": "string" },
        "colores": {
          "type": "object",
          "required": ["primario", "secundario", "acento", "fondo", "texto", "textoInverso"],
          "patternProperties": { "^(primario|secundario|acento|fondo|texto|textoInverso)$": { "type": "string" } },
          "additionalProperties": false
        },
        "fuenteTitulo": { "type": "string" },
        "fuenteTexto": { "type": "string" }
      }
    },
    "escenas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "rol", "t_in", "t_out", "visual"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "rol": { "type": "string", "enum": ["hook", "producto", "paso", "beneficios", "resultado", "testimonio", "cta", "contexto"] },
          "t_in": { "type": "number", "minimum": 0 },
          "t_out": { "type": "number", "minimum": 0 },
          "sync_word_idx": { "type": "integer", "minimum": 0, "description": "Indice de la palabra final en subs.json. Si existe, retime.mjs sobrescribe t_in/t_out de esta y la siguiente escena automáticamente." },
          "enfasis": {
            "type": "object",
            "additionalProperties": false,
            "description": "FUENTE UNICA del enfasis de la escena (triple-sync: pop visual + SFX + karaoke caen en la MISMA palabra). graphics anima esta palabra y audio le pone el acento EN EL MISMO frame; no se declaran indices por separado (anti-drift).",
            "properties": {
              "word_idx": { "type": "integer", "minimum": 0, "description": "Indice base-0 en el flujo de palabras de subs.json de la palabra a enfatizar. El render le da pop EXTRA." },
              "texto": { "type": "string", "description": "La palabra/frase a enfatizar (referencia humana; el render usa word_idx)." },
              "sfx": { "type": "string", "enum": ["pop", "impact", "whoosh", "riser", "subdrop"], "description": "Tipo de SFX que acentua el enfasis (default pop)." },
              "sfx_archivo": { "type": "string", "description": "Archivo del SFX en public/. Si esta, mix-audio coloca el acento EN la palabra del enfasis automaticamente." }
            }
          },
          "scrim": { "type": "string", "enum": ["none", "bottom", "top", "full"] },
          "ocultarSubtitulos": { "type": "boolean", "description": "true en escenas con tarjeta propia (ej. CTA full-screen sin VO con info nueva) para no pisar el subtitulo. Nunca sobre una linea hablada con info." },
          "visual": {
            "type": "object",
            "required": ["intencion", "fuentes"],
            "additionalProperties": false,
            "properties": {
              "intencion": { "type": "string" },
              "fuentes": {
                "type": "array",
                "minItems": 1,
                "description": "Cadena de fallback: el render usa la primera fuente que resuelva.",
                "items": {
                  "type": "object",
                  "required": ["tipo"],
                  "additionalProperties": false,
                  "properties": {
                    "tipo": { "type": "string", "enum": ["asset_cliente", "video_generado", "imagen_generada", "kenburns"] },
                    "archivo": { "type": "string", "description": "Prototipo: candidato en public/. Futuro: resuelto desde el pool." },
                    "match": {
                      "type": "object",
                      "properties": {
                        "categoria": { "type": "string", "enum": ["producto", "proceso", "otro"] },
                        "palabras": { "type": "array", "items": { "type": "string" } }
                      },
                      "additionalProperties": false
                    },
                    "prompt": { "type": "string" },
                    "base": { "type": "string", "enum": ["asset_cliente", "logo", "referencia_marca", "imagen_generada"] },
                    "base_archivo": { "type": "string", "description": "Archivo base en public/ para editar/animar: FLUX.2 edit (imagen_generada con base real) o i2v (video_generado)." },
                    "prompt_movimiento": { "type": "string" },
                    "negative": { "type": "string", "description": "Negative prompt del recurso generado. Va como CAMPO de la API (no inline en el prompt). Si falta, el generador usa uno por defecto." }
                  }
                }
              }
            }
          },
          "overlays": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["componente"],
              "additionalProperties": false,
              "properties": {
                "componente": { "type": "string", "enum": ["TituloIntro", "LowerThird", "CTA", "PasoBadge", "ListaBeneficios", "BrandTag", "PopUp"] },
                "props": { "type": "object" }
              }
            }
          }
        }
      }
    },
    "audio": {
      "type": "object",
      "required": ["modo", "voz"],
      "additionalProperties": false,
      "properties": {
        "modo": { "type": "string", "enum": ["propio", "audio_nativo_ig"] },
        "ig_audio": { "type": "string", "description": "Con modo=audio_nativo_ig: nombre/link del audio nativo o trending que el usuario agrega en IG. El export va SIN cama de música." },
        "voz": {
          "type": "object",
          "required": ["texto", "voz_tts"],
          "additionalProperties": false,
          "properties": {
            "texto": { "type": "string" },
            "voz_tts": { "type": "string" },
            "rate": { "type": "string" }
          }
        },
        "musica": {
          "type": "object",
          "required": ["src", "volumen"],
          "properties": {
            "src": { "type": "string" },
            "volumen": { "type": "number", "minimum": 0, "maximum": 1 },
            "mood": { "type": "string" },
            "duck": { "type": "boolean", "description": "Agachar la música cuando habla la voz (sidechain). Default true." }
          },
          "additionalProperties": true
        },
        "sfx": {
          "type": "array",
          "description": "Cue sheet de efectos. Cada cue se ancla por t (seg), corte (id de escena -> su t_in) o palabra (indice en el flujo de palabras de subs.json).",
          "items": {
            "type": "object",
            "required": ["tipo"],
            "additionalProperties": false,
            "properties": {
              "tipo": { "type": "string", "enum": ["whoosh", "riser", "impact", "pop", "subdrop", "ambience"] },
              "archivo": { "type": "string" },
              "t": { "type": "number", "minimum": 0 },
              "corte": { "type": "string" },
              "palabra": { "type": "integer", "minimum": 0 },
              "vol": { "type": "number", "minimum": 0, "maximum": 2 },
              "dur": { "type": "number", "minimum": 0.05, "maximum": 10, "description": "Largo (seg) al que se recorta el SFX con fade-out (anti-zumbido). Override del default por tipo. ambience va sostenida (sin recorte)." }
            }
          }
        }
      }
    },
    "subtitulos": {
      "type": "object",
      "required": ["auto"],
      "additionalProperties": false,
      "properties": {
        "auto": { "type": "boolean" },
        "estilo": { "type": "string" },
        "maxPalabras": { "type": "integer", "minimum": 1, "maximum": 8 }
      }
    },
    "copy": {
      "type": "object",
      "required": ["caption", "hashtags"],
      "additionalProperties": false,
      "properties": {
        "caption": { "type": "string" },
        "hashtags": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
